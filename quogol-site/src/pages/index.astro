---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout
  title="Home"
  description="Quogol — A privacy-first browser. No tracking. No profiling. Built for you."
>
  <Navbar />

  <main class="pt-16">
    <!-- Hero -->
    <section class="min-h-[90vh] flex flex-col items-center justify-center text-center px-6 py-24">
      <p class="text-qg-accent text-sm font-medium tracking-widest uppercase mb-4">Privacy-First Browser</p>
      <h1 class="font-display font-bold text-5xl md:text-7xl text-qg-text leading-tight mb-6">
        Browse freely.<br />Stay private.
      </h1>
      <p class="text-qg-muted text-lg max-w-xl mb-10">
        Quogol is a fast, clean browser that respects your data — no tracking, no profiling, no compromises.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/download"
          class="px-8 py-3 rounded-lg bg-qg-accent hover:bg-qg-accent-lt text-white font-medium transition-colors"
        >
          Download Quogol
        </a>
        <a
          href="https://github.com/QuogolBrowser"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 rounded-lg border border-qg-border text-qg-muted hover:text-qg-text hover:border-qg-accent transition-colors"
        >
          View on GitHub
        </a>
      </div>
    </section>

    <!-- Features placeholder -->
    <section id="features" class="max-w-5xl mx-auto px-6 py-24">
      <h2 class="font-display font-bold text-3xl text-qg-text mb-12 text-center">Built different</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { title: 'Privacy by Default', desc: 'No telemetry. No data collection. No phone-home behavior.' },
          { title: 'Blazing Fast',       desc: 'Lightweight and responsive even on modest hardware.' },
          { title: 'Anti-Tracking',      desc: 'Built-in protection against fingerprinting and ad trackers.' },
        ].map(f => (
          <div class="p-6 rounded-xl border border-qg-border bg-qg-surface">
            <h3 class="font-display font-semibold text-qg-text mb-2">{f.title}</h3>
            <p class="text-qg-muted text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
