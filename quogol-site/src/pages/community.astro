---
import BaseLayout from '../layouts/BaseLayout.astro';

const crawlers = [
  {
    id: 'quokkle-1',
    name: 'Quokkle-1',
    emoji: '🐢',
    mashup: 'Quokka + Turtle',
    personality: 'Slow, steady, and absolutely thorough.',
    description:
      'Quokkle-1 moves at turtle pace and misses nothing. It\'s Quogol\'s deep-crawl search bot — built to index every corner of a page, follow every link trail, and surface results that fast crawlers miss. Quokkle also powers the Search Chat Bot: a conversational layer on top of search results so you can ask follow-up questions without reformulating queries.',
    traits: ['Deep page indexing', 'Link trail following', 'No shortcuts', 'Powers Search Chat Bot', 'Never misses a footnote'],
    color: 'bg-green-900/20 border-green-800/40',
    textColor: 'text-green-400',
  },
  {
    id: 'quotopus-2',
    name: 'Quotopus-2',
    emoji: '🐙',
    mashup: 'Quokka + Octopus',
    personality: 'Eight arms. All grabbing results simultaneously.',
    description:
      'Quotopus-2 is Quogol\'s parallel-crawl engine — fast and wide. While Quokkle goes deep, Quotopus goes broad. It dispatches multiple crawl threads simultaneously, covering as much surface area as possible in minimum time. When you need fresh, wide-coverage results, Quotopus-2 delivers.',
    traits: ['Parallel crawl threads', 'Maximum surface coverage', 'Near real-time freshness', 'Wide-net indexing', 'Breadth-first traversal'],
    color: 'bg-blue-900/20 border-blue-800/40',
    textColor: 'text-blue-400',
  },
  {
    id: 'quolophant-3',
    name: 'Quolophant-3',
    emoji: '🐘',
    mashup: 'Quokka + Elephant',
    personality: 'Never forgets. Ever.',
    description:
      'Quolophant-3 handles indexing and memory. An elephant never forgets — and Quolophant never loses an indexed result. It maintains long-term index coherence, handles deduplication, manages crawl revisit schedules, and ensures the search index stays consistent over time. The quiet backbone of the Quogol search engine.',
    traits: ['Long-term index management', 'Deduplication engine', 'Crawl revisit scheduling', 'Index coherence', 'Historical result preservation'],
    color: 'bg-amber-900/20 border-amber-800/40',
    textColor: 'text-amber-400',
  },
];

const quailEggsInfo = [
  { label: 'What are they?', value: 'Community contribution currency — earned by participating, contributing, and helping in the Quogol community.' },
  { label: 'How to earn', value: 'File bug reports, contribute to Quolladium, answer questions in Quocord, write documentation, create browser extensions, test beta builds.' },
  { label: 'What they\'re for', value: 'Recognition, community status, and Pro perks for Quogol Pro subscribers (bonus Quail Eggs per billing cycle).' },
  { label: 'Monetary value', value: 'None. Quail Eggs are community currency — they cannot be exchanged for cash.' },
  { label: 'Transferable?', value: 'No — Quail Eggs are tied to your account and reflect your contribution history.' },
];

const contributionAreas = [
  { title: 'Quolladium Engine', desc: 'Rust development on the rendering engine. Bug fixes, performance improvements, standards compliance.', link: 'https://github.com/QuogolBrowser/quogol', label: 'GitHub' },
  { title: 'QuogolBlocker Lists', desc: 'Maintain and improve blocklists. Report missed trackers, submit new patterns, improve coverage.', link: 'https://github.com/QuogolBrowser/quogol', label: 'Contribute' },
  { title: 'Bug Reports', desc: 'Test builds, find issues, file detailed reports. Quality bug reports earn Quail Eggs.', link: 'https://github.com/QuogolBrowser/quogol', label: 'File a Bug' },
  { title: 'Documentation', desc: 'Write or improve docs for Quolladium, QuogolBlocker, Quoton, and user-facing features.', link: 'https://github.com/QuogolBrowser/quogol', label: 'Docs Repo' },
  { title: 'Community Support', desc: 'Help other users in Quocord. Answer questions, share tips, welcome new members.', link: '#quocord', label: 'Join Quocord' },
  { title: 'Extension Development', desc: 'Build extensions for Quogol. Extend the browser without compromising its privacy model.', link: 'https://github.com/QuogolBrowser/quogol', label: 'Dev Docs' },
];
---

<BaseLayout
  title="Community — Quogol"
  description="Quail Eggs, Quocord, the Crawler Squad. Join the Quogol community — built by privacy-first people, for privacy-first people."
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-28 pb-20 px-6">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute bottom-0 right-0 w-[600px] h-[400px] rounded-full bg-qg-accent opacity-8 blur-3xl"></div>
    </div>
    <div class="max-w-5xl mx-auto relative z-10 text-center">
      <div class="text-xs font-medium text-qg-accent uppercase tracking-widest mb-4">Community</div>
      <h1 class="font-display font-black text-5xl md:text-7xl text-qg-text leading-tight mb-6">
        Built together. 🐾
      </h1>
      <p class="text-lg text-qg-muted max-w-xl mx-auto leading-relaxed">
        Quogol is open source. The community isn't a support forum — it's a core part of how the browser gets built, maintained, and improved.
      </p>
    </div>
  </section>

  <!-- Quocord -->
  <section id="quocord" class="py-24 px-6 bg-qg-surface border-y border-qg-border">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <div class="text-xs font-medium text-qg-accent uppercase tracking-widest mb-4">Official Discord</div>
        <h2 class="font-display font-bold text-3xl text-qg-text mb-6 leading-tight">
          Quocord
        </h2>
        <p class="text-qg-muted leading-relaxed mb-6">
          Quocord is the official Quogol Discord server — home to the community, the dev team, beta testers, and the occasional Quokka gif. Come for the browser discussions, stay for the privacy debate and the Quokka appreciation channel.
        </p>
        <ul class="space-y-3 mb-8 text-sm text-qg-muted">
          {[
            '#general — Main community chat',
            '#quolladium-dev — Engine development discussion',
            '#bug-reports — File and track issues',
            '#beta-testers — Early builds and feedback',
            '#quail-eggs — Contribution leaderboard',
            '#quokka-corner — 🐾 You know why',
          ].map(ch => (
            <li class="flex items-center gap-3">
              <span class="text-qg-accent text-xs">#</span>
              <span>{ch}</span>
            </li>
          ))}
        </ul>
        <a
          href="https://discord.gg/quogol"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-qg-accent hover:bg-qg-accent-lt text-white font-medium transition-colors text-sm"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
          </svg>
          Join Quocord
        </a>
      </div>
      <div class="p-8 rounded-xl border border-qg-border bg-qg-bg">
        <div class="font-display font-bold text-qg-text mb-6">Community Stats</div>
        <div class="space-y-4">
          {[
            { label: 'Coming at launch', value: 'Members' },
            { label: 'Open Source', value: 'Quolladium Engine' },
            { label: 'Active', value: 'Beta Program' },
            { label: 'Always open', value: 'Bug Reports' },
          ].map(stat => (
            <div class="flex items-center justify-between py-3 border-b border-qg-border last:border-0">
              <span class="text-qg-muted text-sm">{stat.label}</span>
              <span class="font-medium text-qg-text text-sm">{stat.value}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Crawler Squad -->
  <section id="crawlers" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <div class="text-xs font-medium text-qg-accent uppercase tracking-widest mb-4">Search Infrastructure</div>
        <h2 class="font-display font-bold text-3xl text-qg-text mb-4">
          The Crawler Squad
        </h2>
        <p class="text-qg-muted max-w-lg mx-auto">
          Quogol's search engine runs on three specialized crawlers. Each is a mashup of a Quokka with another animal, each with its own personality and purpose.
        </p>
      </div>

      <div class="space-y-8">
        {crawlers.map(crawler => (
          <div id={crawler.id} class={`p-8 rounded-xl border ${crawler.color} bg-qg-surface`}>
            <div class="flex flex-col md:flex-row md:items-start gap-6">
              <div class="flex-shrink-0 text-center md:text-left">
                <div class="text-6xl mb-2">{crawler.emoji}</div>
                <div class={`text-xs font-medium uppercase tracking-widest ${crawler.textColor}`}>
                  {crawler.mashup}
                </div>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="font-display font-bold text-2xl text-qg-text">{crawler.name}</h3>
                </div>
                <p class={`font-medium mb-4 ${crawler.textColor}`}>{crawler.personality}</p>
                <p class="text-qg-muted text-sm leading-relaxed mb-6">{crawler.description}</p>
                <div class="flex flex-wrap gap-2">
                  {crawler.traits.map(trait => (
                    <span class="px-3 py-1 rounded-full border border-qg-border bg-qg-bg text-qg-muted text-xs">
                      {trait}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quail Eggs -->
  <section id="quail-eggs" class="py-24 px-6 bg-qg-surface border-y border-qg-border">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <div class="text-4xl mb-4">🥚</div>
        <div class="text-xs font-medium text-qg-accent uppercase tracking-widest mb-4">Contribution Currency</div>
        <h2 class="font-display font-bold text-3xl text-qg-text mb-4">Quail Eggs</h2>
        <p class="text-qg-muted max-w-lg mx-auto">
          The Quogol community contribution currency. Earned by contributing to the project, helping other users, and being part of the community.
        </p>
      </div>

      <div class="rounded-xl border border-qg-border overflow-hidden mb-12">
        <div class="divide-y divide-qg-border">
          {quailEggsInfo.map((item, i) => (
            <div class={`flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-8 px-6 py-5 ${i % 2 === 0 ? 'bg-qg-bg' : 'bg-qg-surface'}`}>
              <div class="sm:w-48 text-sm font-medium text-qg-text flex-shrink-0">{item.label}</div>
              <div class="text-qg-muted text-sm leading-relaxed">{item.value}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Platybara -->
      <div class="p-8 rounded-xl border border-qg-border bg-qg-bg">
        <div class="flex items-start gap-4">
          <div class="text-3xl flex-shrink-0">🦦</div>
          <div>
            <h3 class="font-display font-bold text-xl text-qg-text mb-2">Platybara</h3>
            <p class="text-qg-muted text-sm leading-relaxed">
              Platybara is the dev-focused AI training bot — a mashup of a platypus and a capybara because both are objectively excellent animals. Platybara's specialty is HTML, CSS, and JavaScript. It's used internally to generate training data for browser AI features and is available in limited capacity to community contributors. Platybara only works on front-end web stack — no backend, no databases, pure HTML/CSS/JS.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contribution Areas -->
  <section id="contribute" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-display font-bold text-3xl text-qg-text mb-4 text-center">
        How to contribute
      </h2>
      <p class="text-qg-muted text-center mb-12 max-w-lg mx-auto">
        Every contribution earns Quail Eggs and makes the browser better for everyone.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {contributionAreas.map(area => (
          <div class="p-6 rounded-xl border border-qg-border bg-qg-surface flex flex-col gap-3">
            <h3 class="font-display font-bold text-qg-text">{area.title}</h3>
            <p class="text-qg-muted text-sm leading-relaxed flex-1">{area.desc}</p>
            <a
              href={area.link}
              target={area.link.startsWith('http') ? '_blank' : undefined}
              rel={area.link.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="text-xs text-qg-accent-lt hover:underline transition-colors"
            >
              {area.label} →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GitHub CTA -->
  <section class="py-16 px-6 bg-qg-surface border-t border-qg-border">
    <div class="max-w-2xl mx-auto text-center">
      <div class="text-3xl mb-4">🐾</div>
      <h2 class="font-display font-bold text-2xl text-qg-text mb-4">Open source, always.</h2>
      <p class="text-qg-muted text-sm mb-8">
        Quolladium and the core Quogol stack are open source. Read the code. Audit the privacy claims. Fork it. Build on it.
      </p>
      <a
        href="https://github.com/QuogolBrowser/quogol"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-qg-border text-qg-muted hover:text-qg-text hover:border-qg-accent transition-colors text-sm font-medium"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        github.com/QuogolBrowser/quogol
      </a>
    </div>
  </section>
</BaseLayout>
