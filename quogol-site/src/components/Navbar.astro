---
const navLinks = [
  { href: '/#features', label: 'Features' },
  { href: '/#about',    label: 'About' },
  { href: '/download',  label: 'Download' },
];
---

<header class="fixed top-0 inset-x-0 z-50 border-b border-qg-border bg-qg-bg/80 backdrop-blur-md">
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-display font-bold text-qg-text text-lg tracking-tight">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="32" height="32" rx="8" fill="#01696f"/>
        <text x="16" y="22" font-family="sans-serif" font-size="16" font-weight="700" text-anchor="middle" fill="white">Q</text>
      </svg>
      Quogol
    </a>

    <!-- Nav Links -->
    <ul class="hidden md:flex items-center gap-8 text-sm text-qg-muted">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="hover:text-qg-text transition-colors duration-150">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a
      href="/download"
      class="hidden md:inline-flex items-center px-4 py-2 rounded-lg bg-qg-accent hover:bg-qg-accent-lt text-white text-sm font-medium transition-colors duration-150"
    >
      Download
    </a>

    <!-- Mobile menu placeholder -->
    <button
      class="md:hidden text-qg-muted hover:text-qg-text"
      aria-label="Open menu"
      id="mobile-menu-btn"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12h18M3 6h18M3 18h18"/>
      </svg>
    </button>
  </nav>
</header>
